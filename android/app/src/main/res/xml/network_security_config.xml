<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">nseindia.com</domain>
        <domain includeSubdomains="true">query1.finance.yahoo.com</domain>
        <domain includeSubdomains="true">query2.finance.yahoo.com</domain>
        <domain includeSubdomains="true">stooq.com</domain>
        <domain includeSubdomains="true">api.upstox.com</domain>
    </domain-config>
</network-security-config>
